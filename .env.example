# =============================================================================
# PEMOS Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values from your Supabase
# project dashboard (Settings > API).
#
# NEVER commit .env or .env.local to version control.
# =============================================================================

# Supabase Project URL (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Anon Key (Settings > API > Project API keys > anon/public)
# Safe to expose in the browser -- RLS policies protect data
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (Settings > API > Project API keys > service_role)
# NEVER expose this key to the browser or client-side code
# Use only in server-side code, Edge Functions, or migration scripts
SUPABASE_SERVICE_ROLE_KEY=
