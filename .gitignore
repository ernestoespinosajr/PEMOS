# =============================================================================
# PEMOS .gitignore
# =============================================================================

# Environment variables (secrets)
.env
.env.local
.env.production
.env.*.local

# Dependencies
node_modules/

# Build output
.next/
out/
dist/
build/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.idea/
.vscode/
*.code-workspace

# Supabase local
supabase/.temp/

# TypeScript
*.tsbuildinfo

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel

# MCP configuration (local)
.mcp.json

# SQLite WAL/SHM files
*.db-wal
*.db-shm

# Claude Code project management (not application code)
vault/
.claude/
.agents/
CLAUDE.md
schema.sql
skills-lock.json
